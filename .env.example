# Copy this file to .env and fill in real local credentials.
# .env is ignored by git. Keep Apple API keys and private signing material out of commits.

# Developer ID Application identity used by codesign.
# Find it with: security find-identity -p codesigning -v
SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Keychain profile name used by xcrun notarytool after credentials are stored.
NOTARYTOOL_PROFILE="vibe-light-notary"

# App Store Connect API key used to create or refresh the notarytool profile.
# Prefer APPLE_API_KEY_PATH so the .p8 content is not stored directly in .env.
APPLE_API_KEY_PATH="$HOME/path/to/AuthKey_KEYID.p8"
# APPLE_API_KEY="-----BEGIN PRIVATE KEY-----..."
APPLE_API_KEY_ID="KEYID"
APPLE_API_ISSUER="ISSUER_UUID"

# Optional notarization wait timeout.
NOTARYTOOL_TIMEOUT="30m"

# Release checklist defaults used by make desktop-release-notarized.
PYTHON_RUNTIME="$HOME/.platformio/python3"
MINIMUM_DESKTOP_VERSION="dev"
# Leave RELEASE_VERSION empty to use YYYY.MM.DD-dev-<git short sha>.
RELEASE_VERSION=""

# Optional device check after packaging.
ESP32_PORT="/dev/cu.usbmodem1101"
ESP32_BAUD="460800"
